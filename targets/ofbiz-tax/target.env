# Airlift target descriptor: ofbiz-tax
# The ONLY place OFBiz-specific configuration lives. The pipeline is target-agnostic.

TARGET_NAME="ofbiz-tax"
TARGET_REPO="/Volumes/Dancer/Develop/AIRLIFT/ofbiz-framework"
CLAIM_NAMESPACE="TAX"
DOMAIN_EXPERT_PERSONA="a tax accountant or a merchant configuring store taxes"

# Files (relative to this descriptor's directory unless absolute)
SEAM_BRIEF_FILE="seam.md"
HARNESS_CONTRACT="harness/harness-contract.md"

# Deterministic commands (used by exit-criteria runners and stage 4 feedback loop)
TARGET_COMPILE_CMD='cd "$TARGET_REPO" && ./gradlew compileJava compileTestJava -x checkstyleMain -x checkstyleTest --console=plain'
TARGET_TEST_CMD='cd "$TARGET_REPO" && ./gradlew "ofbiz --test component=accounting --test suitename=airliftblind" --console=plain'
TARGET_BACKFILL_TEST_CMD='cd "$TARGET_REPO" && ./gradlew "ofbiz --test component=accounting --test suitename=airliftbackfill" --console=plain'
TEST_RESULTS_DIR="$TARGET_REPO/runtime/logs/test-results"

# Where generated tests land inside the target repo
BLIND_TEST_DIR="$TARGET_REPO/applications/accounting/src/test/java/org/apache/ofbiz/accounting/tax/test/blind"
BACKFILL_TEST_DIR="$TARGET_REPO/applications/accounting/src/test/java/org/apache/ofbiz/accounting/tax/test/backfill"

# Primary source file(s) of the seam (for mutations / refactor verification)
SEAM_PRIMARY_FILE="$TARGET_REPO/applications/accounting/src/main/java/org/apache/ofbiz/accounting/tax/TaxAuthorityServices.java"
